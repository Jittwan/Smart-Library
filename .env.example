# ---------------------------------------------------------------------------
# Smart Library — environment variables
# Copy to `.env` and fill in real values. Never commit your real `.env`.
# ---------------------------------------------------------------------------

# Public app name (shown in the UI and PDF report). Inlined at build time.
NEXT_PUBLIC_APP_NAME="Smart Library"

# Supabase PostgreSQL — runtime connection (use the pooled connection).
# Supabase: Project → Settings → Database → Connection string → "Transaction" pooler.
# If you used the Supabase/Vercel integration, the app also auto-detects its
# POSTGRES_PRISMA_URL / POSTGRES_URL / POSTGRES_URL_NON_POOLING variables, so
# DATABASE_URL / DIRECT_URL below are optional in that case.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"

# Direct (non-pooled) connection used by `prisma migrate` / `prisma db push`.
# Supabase: the "Session"/direct connection on port 5432.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase Storage (server-side only — keep the service role key secret).
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Secret used to sign member/librarian session cookies (JWT). Use a long random string.
SESSION_SECRET="change-me-to-a-long-random-string"

# Librarian (admin) login credentials.
ADMIN_EMAIL="librarian@smartlibrary.local"
ADMIN_PASSWORD="change-me"
